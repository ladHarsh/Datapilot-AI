# ── Line ending normalization ─────────────────────────────────────────────────
# Normalize all text files to LF on checkout
* text=auto eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicitly mark binary files (do not touch line endings)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.xlsx binary
*.xls  binary
